APP_NAME="Warehouse Reservation"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_YOUR_KEY
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/database/database.sqlite

QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file

SUPPLIER_BASE_URL=http://app:8000
LOG_CHANNEL=stderr
LOG_LEVEL=info
